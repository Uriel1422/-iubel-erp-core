# Dockerfile.backend — Motor Core Iubel ERP
FROM node:20-slim

# Crear directorio de trabajo
WORKDIR /app

# Instalar dependencias esenciales
COPY package*.json ./
RUN npm install --production

# Copiar el código fuente
COPY . .

# Exponer el puerto de la API
EXPOSE 3001

# Configuración de seguridad: No correr como root
USER node

# Comando de inicio
CMD ["node", "server.js"]
